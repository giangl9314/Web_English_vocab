RewriteEngine On RewriteBase /WEB_ENGLISH_VOCAB/pages/admin/ # Không rewrite nếu đã là index.php 
RewriteCond %{REQUEST_URI} index\.php [NC] 
RewriteRule ^ - [L] 
 
# Redirect tất cả file .html qua index.php 
RewriteCond %{REQUEST_FILENAME} -f 
RewriteCond %{REQUEST_FILENAME} \.html$ [NC] 
RewriteRule ^(.+\.html)$ index.php?page=$1 [L,QSA] 
 
# Nếu truy cập folder /admin/ thì load dashboard 
RewriteCond %{REQUEST_URI} /admin/?$ 
RewriteRule ^$ index.php?page=trangchu_admin.html [L,QSA]
# Ngăn chặn listing directory
Options -Indexes 